{
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  // Markdown Lint
  "markdownlint.config": {
    "MD013": false,
    "MD033": false,
    "MD041": false
  },
  "markdownlint.lintWorkspaceGlobs": [
    "**/*.{md,mdx}"
  ],
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true
  },
  "[mdx]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true
  },
  "files.associations": {
    "*.mdx": "markdown"
  }
}